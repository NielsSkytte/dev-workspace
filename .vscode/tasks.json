  // ─────────────────────────────────────────────────────────────
  //  DEV — Claude Code project launcher
  //
  //  Usage: Ctrl+Shift+P → "Tasks: Run Task" → pick a project
  //
  //  Adding a new project:
  //    1. Copy one of the project blocks below
  //    2. Update "label" → "Claude · [category/ProjectName]"
  //    3. Update "cwd"   → path relative to ${workspaceFolder}
  //    4. Save and the task appears immediately — no reload needed
  // ─────────────────────────────────────────────────────────────
  "version": "2.0.0",
  "tasks": [

    // ── Workspace root ─────────────────────────────────────────
    {
      "label": "Claude · DEV root",
      "detail": "Launch Claude Code at workspace root (global context only)",
      "type": "shell",
      "command": "claude",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "claude",
        "close": false
      },
      "problemMatcher": []
    },

