{
  "autoMemoryEnabled": false,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"C:\\Dev\\.claude\\hooks\\session-start.ps1\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:\\Dev\\.claude\\hooks\\capture_turn.py\""
          }
        ]
      }
    ]
  }
}
